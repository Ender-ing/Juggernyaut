/**
 *
 * This is the ANTLR grammar file for the Juggernyaut Lexer!
 *
 * (Only contains finalised implementations!)
 *
**/

lexer grammar JuggernyautLexer;

// Options
options {
    language=Cpp;
}

import LexerIgnores, LexerSymbols, LexerLiterals, LexerKeywords;

TMP
    : 'TMP'
    ;
TMP2
    : 'TMP2'
    ;
