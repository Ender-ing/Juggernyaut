{
    "name": "juggernyaut",
    "main": "scripts/extension.js",
    "browser": "scripts/extension.light.js",
    "displayName": "Juggernyaut",
    "description": "All you need to start working with the J command programming language!",
    "version": "0.0.1",
    "preview": true,
    "engines": {
        "vscode": "^1.94.0"
    },
    "publisher": "Endering",
    "contributes": {
        "configuration": {
            "type": "object",
            "title": "Juggernyaut",
            "properties": {
                "juggernyaut.sdkPath": {
                    "type": "string",
                    "default": "",
                    "description": "The absolute path to your preferred Juggernyaut SDK version."
                },
                "juggernyaut.trace.server": {
                    "scope": "window",
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the server."
                },
                "juggernyaut.maxNumberOfProblems": {
                    "scope": "resource",
                    "type": "number",
                    "default": 250,
                    "description": "Controls the maximum number of problems produced by the server."
                }
            }
        },
        "configurationDefaults": {
            "[juggernyaut]": {
                "editor.maxTokenizationLineLength": 2500,
                "editor.formatOnSave": true,
                "editor.formatOnType": true
            },
            "files.associations": {
                "*.jug": "juggernyaut"
            }
        },
        "languages": [
            {
                "id": "juggernyaut",
                "aliases": [
                    "Juggernyaut",
                    "Jug"
                ],
                "extensions": [
                    ".jug"
                ],
                "formatter": {
                    "scheme": "file",
                    "language": "juggernyaut"
                },
                "configuration": "./configurations/juggernyaut-language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "juggernyaut",
                "scopeName": "source.juggernyaut",
                "path": "./syntaxes/juggernyaut.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "juggernyaut",
                "path": "./snippets/juggernyaut.code-snippets.json"
            }
        ],
        "commands": [
            {
                "command": "juggernyaut.docs",
                "title": "Check the latest Juggernyaut documentation!",
                "category": "Juggernyaut"
            },
            {
                "command": "juggernyaut.server.stop",
                "title": "Terminate the (running) Juggernyaut language server and its cycle!",
                "category": "Juggernyaut"
            },
            {
                "command": "juggernyaut.server.resume",
                "title": "Resume the Juggernyaut language server cycle!",
                "category": "Juggernyaut"
            },
            {
                "command": "juggernyaut.internal",
                "title": "Show the Juggernyaut (internal) output channel!",
                "category": "Juggernyaut"
            }
        ],
        "files": [
            {
                "language": "juggernyaut",
                "scheme": "file",
                "pattern": "**/*.jug"
            }
        ]
    },
    "activationEvents": [
        "onLanguage:juggernyaut",
        "workspaceContains:**/*.jug"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Ender-ing/juggernyaut.git"
    },
    "homepage": "https://ender.ing/",
    "categories": [
        "Programming Languages",
        "Snippets",
        "Language Packs",
        "Formatters"
    ],
    "keywords": [
        "jug",
        "juggernyaut",
        "programming language",
        "general programming language"
    ],
    "scripts": {
        "build": "esbuild ./scripts/extension.ts --bundle --outfile=./scripts/extension.js --external:vscode --format=cjs --platform=node && esbuild ./scripts/extension.light.ts --bundle --outfile=./scripts/extension.light.js --external:vscode --format=cjs --platform=browser --minify",
        "package:desktop": "vsce package --no-dependencies --baseContentUrl https://github.com/Ender-ing/juggernyaut/tree/main/extensions/VSCode",
        "package:web": "vsce package --no-dependencies --baseContentUrl https://github.com/Ender-ing/juggernyaut/tree/main/extensions/VSCode --target web",
        "package:all": "npm run package:desktop && npm run package:web",
        "win-copy-license": "xcopy /y ..\\..\\LICENSE .",
        "lix-copy-license": "cp ../../LICENSE .",
        "win-delete-vsix": "del juggernyaut*.vsix",
        "lix-delete-vsix": "rm -f juggernyaut*.vsix",
        "win-delete-license": "del LICENSE",
        "lix-delete-license": "rm -f LICENSE",
        "win-package": "npm run win-delete-vsix && npm run win-delete-license && npm run win-copy-license && npm run build && npm run package:all && npm run win-delete-license",
        "lix-package": "npm run lix-delete-vsix && npm run lix-delete-license && npm run lix-copy-license && npm run build && npm run package:all && npm run lix-delete-license"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/vscode": "^1.94.0",
        "@types/which": "^3.0.4",
        "@vscode/vsce": "^3.2.1",
        "esbuild": "^0.27.4",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "which": "^6.0.1"
    }
}
